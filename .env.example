# ============================================================
# MENS CATALY - 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ============================================================

# ============================================================
# microCMS
# https://app.microcms.io/
# ============================================================
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key
MICROCMS_WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# Supabase
# https://supabase.com/dashboard/
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Claude AI (記事生成・分析)
# https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
# 記事生成モデル (default: claude-sonnet-4-6)
ANTHROPIC_MODEL_ARTICLE=claude-sonnet-4-6
# 分析モデル (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL_ANALYSIS=claude-haiku-4-5-20251001

# ============================================================
# Cloudinary (画像管理)
# https://cloudinary.com/console/
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================
# Ideogram API (AI画像生成)
# https://ideogram.ai/
# ============================================================
IDEOGRAM_API_KEY=your-ideogram-api-key

# ============================================================
# Google (GSC / GA4 / BigQuery)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-gcp-project-id
GA4_PROPERTY_ID=your-ga4-property-id
GSC_SITE_URL=https://menscataly.com
BQ_DATASET_ID=analytics_000000000

# ============================================================
# Admin / 認証 / セキュリティ
# ============================================================
ADMIN_API_KEY=your-admin-api-key-change-in-production
CRON_SECRET=your-vercel-cron-secret

# ============================================================
# Pipeline (自動投稿パイプライン)
# ============================================================
PIPELINE_API_KEY=your-pipeline-api-key-change-in-production
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# 通知 (Slack)
# ============================================================
SLACK_WEBHOOK_URL=your-slack-webhook-url
# チャンネルのオーバーライド (未設定時はデフォルトチャンネルを使用)
# SLACK_CHANNEL_CRITICAL=#alerts-critical
# SLACK_CHANNEL_WARNING=#alerts-warning
# SLACK_CHANNEL_INFO=#alerts-info

# ============================================================
# 通知 (Email) — SendGrid または SMTP
# ============================================================
ALERT_EMAIL_TO=admin@menscataly.com
# SendGrid (推奨)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SMTP (代替)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# ============================================================
# ASP (A8.net)
# ============================================================
A8_MEDIA_ID=your-a8-media-id
NEXT_PUBLIC_A8_MEDIA_ID=your-a8-media-id
NEXT_PUBLIC_A8_LINKMGR_CONFIG_ID=your-a8-linkmgr-config-id

# ============================================================
# ASP APIキー (各ASPで取得、未設定の場合はモックデータを使用)
# ============================================================
# AFB_API_KEY=your-afb-api-key
# A8_API_KEY=your-a8-api-key
# ACCESSTRADE_API_KEY=your-accesstrade-api-key
# VALUECOMMERCE_API_KEY=your-valuecommerce-api-key
# FELMAT_API_KEY=your-felmat-api-key

# ============================================================
# pytrends マイクロサービス (将来実装: Cloud Run)
# 未設定の場合はモックデータを使用
# ============================================================
# PYTRENDS_SERVICE_URL=https://pytrends-xxxx.a.run.app

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_SITE_URL=https://menscataly.com
NEXT_PUBLIC_BASE_URL=https://menscataly.com
NODE_ENV=development
