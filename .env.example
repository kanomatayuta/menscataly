# ============================================================
# MENS CATALY - 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ============================================================

# ============================================================
# microCMS
# https://app.microcms.io/
# ============================================================
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key
MICROCMS_WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# Supabase
# https://supabase.com/dashboard/
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Claude AI (記事生成・分析)
# https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================
# Cloudinary (画像管理)
# https://cloudinary.com/console/
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================
# Ideogram API (AI画像生成)
# https://ideogram.ai/
# ============================================================
IDEOGRAM_API_KEY=your-ideogram-api-key

# ============================================================
# Google (GSC / GA4 / BigQuery)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-gcp-project-id
GA4_PROPERTY_ID=your-ga4-property-id
GSC_SITE_URL=https://menscataly.com

# ============================================================
# Pipeline (自動投稿パイプライン)
# ============================================================
PIPELINE_API_KEY=your-pipeline-api-key-change-in-production
GA4_PROPERTY_ID=your-ga4-property-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# pytrends マイクロサービス (将来実装: Cloud Run)
# 未設定の場合はモックデータを使用
# ============================================================
# PYTRENDS_SERVICE_URL=https://pytrends-xxxx.a.run.app

# ============================================================
# ASP APIキー (各ASPで取得、未設定の場合はモックデータを使用)
# ============================================================
# AFB_API_KEY=your-afb-api-key
# A8_API_KEY=your-a8-api-key
# ACCESSTRADE_API_KEY=your-accesstrade-api-key
# VALUECOMMERCE_API_KEY=your-valuecommerce-api-key
# FELMAT_API_KEY=your-felmat-api-key

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_SITE_URL=https://menscataly.com
NODE_ENV=development
