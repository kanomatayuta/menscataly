          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pca4" value="翌日の PLAN へ" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D32F2F;strokeWidth=3;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="pdca_a" target="pdca_p">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
