        <mxCell id="art1" value="&lt;b style='font-size:12px'&gt;タイプ①: クリニック比較記事&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;（最頻出・CVR最高）&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;文字数: 5,000〜7,000字&lt;br&gt;H2: 6〜8個 / H3: 15〜25個&lt;br&gt;必須: 比較表・FAQ5問&lt;br&gt;CTA: 本文中3箇所&lt;br&gt;クリニック情報自動注入&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="700" width="300" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="art2" value="&lt;b style='font-size:12px'&gt;タイプ②: 断言コラム記事&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;（SNS拡散・入口記事）&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;文字数: 2,500〜4,000字&lt;br&gt;トーン: 断言調&lt;br&gt;「〜すべき」「〜は損している」&lt;br&gt;CTA: 本文中2箇所+末尾1箇所&lt;br&gt;共感→断言→解決策→行動促進&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="700" width="300" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="art3" value="&lt;b style='font-size:12px'&gt;タイプ③: ロングテール記事&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;（競合回避・CVR高）&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;例:&lt;br&gt;「ワックス 髪 立ち上がらない AGA」&lt;br&gt;「婚活 うまくいかない 髪」&lt;br&gt;「青髭 コンプレックス 解消」&lt;br&gt;「[地域名] AGA クリニック 安い」&lt;br&gt;「[クリニック名] 口コミ 評判」&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="700" width="300" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="art4" value="&lt;b style='font-size:12px'&gt;記事生成品質管理&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;薬機法NGワード自動検出:&lt;br&gt;「治る」→「改善をサポート」&lt;br&gt;「必ず効く」→「多くの方に効果」&lt;br&gt;「副作用なし」→「医師に相談」&lt;br&gt;&lt;br&gt;免責事項テンプレート自動挿入&lt;br&gt;月1回 人によるプロンプト改善&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="700" width="300" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="brand" value="&lt;b style='font-size:12px'&gt;ブランドアイデンティティ&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;名称: メンズカタリ（MENS CATALY）&lt;br&gt;コピー: 「変わるきっかけを、語る。」&lt;br&gt;ダブルミーニング:&lt;br&gt;  catalyst（触媒）× 語り（katari）&lt;br&gt;&lt;br&gt;編集方針: 断言・煽り・共感の3パターン&lt;br&gt;「男は〇〇しろ」「〜は損している」&lt;br&gt;「実は知らなかった」&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1350" y="700" width="320" height="200" as="geometry"/>
