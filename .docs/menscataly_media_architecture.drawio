        <!-- Article Types Title -->
        <mxCell id="art_title" value="&lt;b style='font-size:13px'&gt;記事タイプ &amp; Claude プロンプト設計&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#37474F;" vertex="1" parent="1">
