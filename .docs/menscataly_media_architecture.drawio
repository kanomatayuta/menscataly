        <mxCell id="alert" value="&lt;b style='font-size:11px'&gt;自動アラート&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;順位±5位&lt;br&gt;CTR 50%以下&lt;br&gt;薬機法フラグ→自動非公開&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#D32F2F;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
