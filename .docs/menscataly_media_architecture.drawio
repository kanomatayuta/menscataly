        </mxCell>
        <mxCell id="t_next" value="&lt;font color='#FFFFFF'&gt;&lt;b&gt;翌朝→&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1430" y="72" width="80" height="25" as="geometry"/>
        </mxCell>

        <!-- Phase 1: Data Collection -->
        <mxCell id="p1" value="&lt;b&gt;① データ取得&lt;/b&gt;&lt;br&gt;&lt;br&gt;Google Trends&lt;br&gt;News RSS&lt;br&gt;GA4 Data API&lt;br&gt;ASP API&lt;br&gt;&lt;br&gt;&lt;i&gt;◆ PDCA入力&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="120" width="180" height="150" as="geometry"/>
        </mxCell>

        <!-- Phase 2: Analysis -->
        <mxCell id="p2" value="&lt;b&gt;② 分析&lt;/b&gt;&lt;br&gt;&lt;br&gt;トレンドスコアリング&lt;br&gt;記事パフォーマンス分析&lt;br&gt;競合ギャップ分析&lt;br&gt;ASP収益分析&lt;br&gt;&lt;br&gt;&lt;i&gt;Claude Haiku + BigQuery&lt;/i&gt;&lt;br&gt;&lt;i&gt;◆ PDCAコア&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="190" height="170" as="geometry"/>
        </mxCell>

        <!-- Phase 3: AI Judgment -->
        <mxCell id="p3" value="&lt;b&gt;③ AI判断&lt;/b&gt;&lt;br&gt;&lt;br&gt;新規記事5本を選定&lt;br&gt;改善記事3本を選定&lt;br&gt;優先KW指定&lt;br&gt;高RPMパターン適用&lt;br&gt;&lt;br&gt;&lt;i&gt;Claude Sonnet&lt;/i&gt;&lt;br&gt;&lt;i&gt;◆ PDCA中核&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#D1C4E9;strokeColor=#4527A0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="180" height="170" as="geometry"/>
        </mxCell>

        <!-- Phase 4: Content Generation -->
        <mxCell id="p4" value="&lt;b&gt;④ 記事生成&lt;/b&gt;&lt;br&gt;&lt;br&gt;新規記事生成（5,000-7,000字）&lt;br&gt;リライト（旧版バックアップ）&lt;br&gt;薬機法チェック内蔵&lt;br&gt;ASPリンク自動挿入&lt;br&gt;サムネイル生成&lt;br&gt;&lt;br&gt;&lt;i&gt;Claude Sonnet + Ideogram&lt;/i&gt;&lt;br&gt;&lt;i&gt;◆ PDCA実行&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="690" y="110" width="230" height="190" as="geometry"/>
