        <mxCell id="rep_monthly" value="&lt;b&gt;月次レポート&lt;/b&gt;&lt;br&gt;毎月1日 09:00 配信&lt;br&gt;&lt;br&gt;【分析】月間KPI実績 / ROI計算&lt;br&gt;AIコスト実績 / 記事平均順位&lt;br&gt;【改善】リライト本数 / 順位改善幅&lt;br&gt;【計画】翌月目標 / Phase移行判断&lt;br&gt;PDF化→Google Drive自動保存" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#3F51B5;" vertex="1" parent="1">
          <mxGeometry x="420" y="620" width="340" height="140" as="geometry"/>
