        <!-- Phase 5: Publish -->
        <mxCell id="p5" value="&lt;b&gt;⑤ 公開&lt;/b&gt;&lt;br&gt;&lt;br&gt;microCMS自動投稿&lt;br&gt;Vercel ISR即時公開&lt;br&gt;Search Consoleリクエスト&lt;br&gt;SNS自動投稿（Phase5〜）&lt;br&gt;&lt;br&gt;&lt;i&gt;microCMS API + Vercel&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="950" y="120" width="200" height="170" as="geometry"/>
        </mxCell>

        <!-- Phase 6: Measure -->
        <mxCell id="p6" value="&lt;b&gt;⑥ 計測&lt;/b&gt;&lt;br&gt;&lt;br&gt;GA4日次集計&lt;br&gt;ASP成果取得&lt;br&gt;順位トラッキング&lt;br&gt;健全性スコア算出&lt;br&gt;&lt;br&gt;&lt;i&gt;GA4 API + Claude Haiku&lt;/i&gt;&lt;br&gt;&lt;i&gt;◆ PDCA入力&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#CFD8DC;strokeColor=#37474F;strokeWidth=2;" vertex="1" parent="1">
