        <!-- Human Intervention Note -->
        <mxCell id="human_note" value="&lt;b&gt;🧑 人間の介入ポイント&lt;/b&gt;&lt;br&gt;&lt;br&gt;① ASP登録・提携申請（初期1回のみ）&lt;br&gt;② プロンプトチューニング（月1回）&lt;br&gt;③ クリニック情報の正確性確認（月1回）&lt;br&gt;④ コンテンツ品質監査（月1回・YMYL対策）&lt;br&gt;&lt;br&gt;&lt;i&gt;上記以外は全て自動化&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;" vertex="1" parent="1">
