        <mxCell id="t_0630" value="&lt;b style='color:#FFFFFF;font-size:11px'&gt;06:30&lt;/b&gt;" style="text;html=1;align=center;" vertex="1" parent="1"><mxGeometry x="830"  y="108" width="80" height="24" as="geometry"/></mxCell>
        <mxCell id="t_0730" value="&lt;b style='color:#FFFFFF;font-size:11px'&gt;07:30&lt;/b&gt;" style="text;html=1;align=center;" vertex="1" parent="1"><mxGeometry x="1110" y="108" width="80" height="24" as="geometry"/></mxCell>
