        <!-- Report Section Title -->
        <mxCell id="report_title" value="&lt;b style='font-size:13px'&gt;自動レポート設計&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="660" y="730" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="rep_weekly" value="&lt;b style='font-size:12px'&gt;週次レポート&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;毎週月曜 08:00 配信&lt;br&gt;&lt;br&gt;【分析】総PV・前週比 / ASP収益・RPM&lt;br&gt;TOP10記事 / 順位変動一覧&lt;br&gt;【改善】リライト記事一覧 / CTA変更箇所&lt;br&gt;【予定】今週の新規候補 / リライト3本&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="780" width="420" height="160" as="geometry"/>
