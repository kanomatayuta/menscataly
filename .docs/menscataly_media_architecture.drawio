        <!-- Phase 2: Analysis -->
        <mxCell id="p2" value="&lt;b style='font-size:12px'&gt;② 分析&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;トレンドスコアリング&lt;br&gt;記事パフォーマンス分析&lt;br&gt;競合ギャップ分析&lt;br&gt;ASP収益分析&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;Claude Haiku 4.5 + BigQuery&lt;br&gt;◆ PDCAコア&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="155" width="220" height="190" as="geometry"/>
        </mxCell>

        <!-- Phase 3: AI Judgment -->
        <mxCell id="p3" value="&lt;b style='font-size:12px'&gt;③ AI判断&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;新規記事5本を選定&lt;br&gt;改善記事3本を選定&lt;br&gt;優先KW指定&lt;br&gt;高RPMパターン適用&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;Claude Sonnet 4.6&lt;br&gt;◆ PDCA中核&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#D1C4E9;strokeColor=#4527A0;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="155" width="220" height="190" as="geometry"/>
        </mxCell>

        <!-- Phase 4: Content Generation -->
        <mxCell id="p4" value="&lt;b style='font-size:12px'&gt;④ 記事生成&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;新規記事生成（5,000-7,000字）&lt;br&gt;リライト（旧版バックアップ）&lt;br&gt;薬機法チェック内蔵&lt;br&gt;ASPリンク自動挿入&lt;br&gt;サムネイル生成&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;Claude Sonnet 4.6 + Ideogram&lt;br&gt;◆ PDCA実行&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="145" width="240" height="210" as="geometry"/>
        </mxCell>

        <!-- Phase 5: Publish -->
        <mxCell id="p5" value="&lt;b style='font-size:12px'&gt;⑤ 公開&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;microCMS自動投稿&lt;br&gt;Vercel ISR即時公開&lt;br&gt;Search Consoleリクエスト&lt;br&gt;SNS自動投稿（Phase5〜）&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;microCMS API + Vercel&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
