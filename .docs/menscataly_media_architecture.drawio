        <mxCell id="rep_alert" value="&lt;b&gt;即時アラート&lt;/b&gt;&lt;br&gt;&lt;br&gt;順位±5位以上の変動&lt;br&gt;ASP CTR 50%以下&lt;br&gt;薬機法フラグ発生→自動非公開&lt;br&gt;圏外落ち→リライト自動起動&lt;br&gt;&lt;br&gt;Slack通知 + メール（重大案件）" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#D32F2F;" vertex="1" parent="1">
          <mxGeometry x="790" y="620" width="340" height="130" as="geometry"/>
