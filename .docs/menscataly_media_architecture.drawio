        <mxCell id="cost5" value="&lt;b style='font-size:11px'&gt;ドメイン&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;~100円/月&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="940" y="1060" width="180" height="80" as="geometry"/></mxCell>
