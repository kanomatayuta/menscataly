        <!-- PDCA Cycle Section -->
        <mxCell id="pdca_title" value="&lt;b&gt;AI自律 PDCA サイクル詳細&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#D32F2F;" vertex="1" parent="1">
