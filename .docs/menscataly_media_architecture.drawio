        <!-- Phase 1: Data Collection -->
        <mxCell id="p1" value="&lt;b style='font-size:12px'&gt;① データ取得&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Google Trends&lt;br&gt;News RSS&lt;br&gt;GA4 Data API&lt;br&gt;ASP API&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;◆ PDCA入力&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="220" height="180" as="geometry"/>
