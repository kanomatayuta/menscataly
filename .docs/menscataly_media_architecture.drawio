        </mxCell>

        <!-- PLAN -->
        <mxCell id="pdca_p" value="&lt;b&gt;P - PLAN（計画）&lt;/b&gt;&lt;br&gt;&lt;br&gt;トレンドスコアTop5→新規記事候補&lt;br&gt;健全性スコア低下→改善候補&lt;br&gt;競合ギャップ大きいKW優先&lt;br&gt;高RPMパターンを新規に適用&lt;br&gt;&lt;b&gt;日次上限: 新規5本 + 改善3本&lt;/b&gt;&lt;br&gt;&lt;br&gt;毎日 06:00 / Claude自動生成" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="370" width="340" height="160" as="geometry"/>
        </mxCell>

        <!-- DO -->
        <mxCell id="pdca_d" value="&lt;b&gt;D - DO（実行）&lt;/b&gt;&lt;br&gt;&lt;br&gt;最適プロンプトで記事生成&lt;br&gt;薬機法チェック内蔵&lt;br&gt;競合ギャップ追記・補完&lt;br&gt;リライト時は旧版バックアップ&lt;br&gt;microCMS→Vercel ISR公開&lt;br&gt;&lt;br&gt;毎日 06:30-07:30 / Claude Sonnet" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="420" y="370" width="340" height="160" as="geometry"/>
        </mxCell>

        <!-- CHECK -->
        <mxCell id="pdca_c" value="&lt;b&gt;C - CHECK（検証）&lt;/b&gt;&lt;br&gt;&lt;br&gt;公開7日後: 順位変動計測&lt;br&gt;ASP CTR・CV率を記事別集計&lt;br&gt;滞在時間・直帰率でUX品質判定&lt;br&gt;健全性スコア基準値以下→改善フラグ&lt;br&gt;順位±5位以上→即時アラート&lt;br&gt;&lt;br&gt;毎日 23:00 / GA4 API + Claude Haiku" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="370" width="340" height="160" as="geometry"/>
        </mxCell>

        <!-- ACT -->
        <mxCell id="pdca_a" value="&lt;b&gt;A - ACT（改善）&lt;/b&gt;&lt;br&gt;&lt;br&gt;競合ギャップを埋める追記&lt;br&gt;CTA位置・文言を最適化&lt;br&gt;見出し構成・内部リンク再設計&lt;br&gt;成功パターン→次の記事に反映&lt;br&gt;失敗パターン→プロンプトから除外&lt;br&gt;&lt;br&gt;翌朝自動実行 / Claude自律判断" style="rounded=1;whiteSpace=wrap;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1160" y="370" width="340" height="160" as="geometry"/>
        </mxCell>

        <!-- PDCA circular arrows -->
        <mxCell id="pca1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#D32F2F;strokeWidth=3;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pdca_p" target="pdca_d">
