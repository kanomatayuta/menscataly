        <mxCell id="pa2" value="&lt;span style='font-size:9px'&gt;分析結果&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;html=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa3" value="&lt;span style='font-size:9px'&gt;指示&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;html=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa4" value="&lt;span style='font-size:9px'&gt;記事データ&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;html=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pa5" value="&lt;span style='font-size:9px'&gt;公開完了&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;html=1;fontSize=9;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p5" target="p6"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- PDCA Section Title -->
        <mxCell id="pdca_title" value="&lt;b style='font-size:14px;color:#D32F2F'&gt;AI自律 PDCA サイクル詳細&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#D32F2F;" vertex="1" parent="1">
          <mxGeometry x="660" y="390" width="400" height="35" as="geometry"/>
        </mxCell>

        <!-- PLAN -->
        <mxCell id="pdca_p" value="&lt;b style='font-size:12px'&gt;P - PLAN（計画）&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;トレンドスコアTop5→新規記事候補&lt;br&gt;健全性スコア低下→改善候補&lt;br&gt;競合ギャップ大きいKW優先&lt;br&gt;高RPMパターンを新規に適用&lt;br&gt;&lt;b&gt;日次上限: 新規5本 + 改善3本&lt;/b&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;毎日 06:00 / Claude自動生成&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="445" width="380" height="190" as="geometry"/>
        </mxCell>

        <!-- DO -->
        <mxCell id="pdca_d" value="&lt;b style='font-size:12px'&gt;D - DO（実行）&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;最適プロンプトで記事生成&lt;br&gt;薬機法チェック内蔵&lt;br&gt;競合ギャップ追記・補完&lt;br&gt;リライト時は旧版バックアップ&lt;br&gt;microCMS→Vercel ISR公開&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;毎日 06:30-07:30 / Claude Sonnet 4.6&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="445" width="380" height="190" as="geometry"/>
        </mxCell>

        <!-- CHECK -->
        <mxCell id="pdca_c" value="&lt;b style='font-size:12px'&gt;C - CHECK（検証）&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;公開7日後: 順位変動計測&lt;br&gt;ASP CTR・CV率を記事別集計&lt;br&gt;滞在時間・直帰率でUX品質判定&lt;br&gt;健全性スコア基準値以下→改善フラグ&lt;br&gt;順位±5位以上→即時アラート&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;毎日 23:00 / GA4 API + Claude Haiku 4.5&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="445" width="380" height="190" as="geometry"/>
        </mxCell>

        <!-- ACT -->
        <mxCell id="pdca_a" value="&lt;b style='font-size:12px'&gt;A - ACT（改善）&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;競合ギャップを埋める追記&lt;br&gt;CTA位置・文言を最適化&lt;br&gt;見出し構成・内部リンク再設計&lt;br&gt;成功パターン→次の記事に反映&lt;br&gt;失敗パターン→プロンプトから除外&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;i style='font-size:10px'&gt;翌朝自動実行 / Claude自律判断&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#F8BBD0;strokeColor=#C2185B;strokeWidth=2;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1350" y="445" width="380" height="190" as="geometry"/>
        </mxCell>

        <!-- PDCA circular arrows -->
        <mxCell id="pca1" value="&lt;span style='font-size:9px'&gt;実行&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D32F2F;strokeWidth=3;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pdca_p" target="pdca_d"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pca2" value="&lt;span style='font-size:9px'&gt;検証&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D32F2F;strokeWidth=3;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pdca_d" target="pdca_c"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pca3" value="&lt;span style='font-size:9px'&gt;改善&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D32F2F;strokeWidth=3;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pdca_c" target="pdca_a"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pca4" value="&lt;b style='font-size:10px'&gt;翌日の PLAN へ循環&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#D32F2F;strokeWidth=3;dashed=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;fontSize=10;" edge="1" parent="1" source="pdca_a" target="pdca_p">
          <mxGeometry relative="1" as="geometry">
